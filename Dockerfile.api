FROM python:3.11-slim

WORKDIR /app

COPY requirements.api.txt .
RUN pip install --no-cache-dir -r requirements.api.txt

COPY api/       ./api/
COPY db/        ./db/

RUN mkdir -p /app/db

ENV PYTHONUNBUFFERED=1

EXPOSE 8000

# gunicorn for production; keep workers low to limit SQLite WAL write contention.
CMD ["gunicorn", "api.main:app", \
     "--bind", "0.0.0.0:8000", \
     "--workers", "2", \
     "--timeout", "60", \
     "--keep-alive", "5", \
     "--worker-connections", "100"]
