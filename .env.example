# Required: your Anthropic API key for AI page categorization
ANTHROPIC_API_KEY=sk-ant-...

# Path to SQLite database inside the container (do not change unless you know why)
DATABASE_PATH=/app/db/darkseek.db

# Tor SOCKS5 proxy address (matches docker-compose service name)
TOR_PROXY=socks5h://tor:9050

# Delay between crawler requests in seconds (be polite to .onion servers)
CRAWLER_DELAY=3

# Number of concurrent crawler fetches (keep low on 1GB RAM)
CRAWLER_WORKERS=2

# Idle wait (seconds) when every DB refill tier is empty before retrying
EMPTY_QUEUE_SLEEP=60

# Allowed CORS origins, comma-separated (leave empty for same-origin only)
# Example: CORS_ORIGINS=https://darkseek.com,https://www.darkseek.com
CORS_ORIGINS=
